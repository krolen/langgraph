      "WebFetch(domain:toronto.ctvnews.ca)",
      "WebFetch(domain:www.ctvnews.ca)",
      "Bash(git:*)",
      "WebFetch(domain:docs.aegra.dev)",
      "WebFetch(domain:docs.searxng.org)",
      "Bash(uv venv:*)",
      "Bash(which bash:*)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__new_page",
